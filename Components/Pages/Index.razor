@page "/"
@using MundialDosmilVeintiSeis.Models
@using static MundialDosmilVeintiSeis.Models.Enums

<MudContainer MaxWidth="MaxWidth.Medium" Class="my-6">

    <MudText Typo="Typo.h4"
             Align="Align.Center"
             GutterBottom="true"
             Style="font-weight:600;">
        Mundial 2026 ⚽
    </MudText>

    @if (_isLoading)
    {
        <div class="d-flex justify-center my-10">
            <MudProgressCircular Indeterminate="true" />
        </div>
    }
    else
    {
        <!-- CALENDARIO -->
        <div class="calendar-wrapper">
            <div class="calendar-strip">
                @foreach (var date in visibleDates)
                {
                    var isSelected = date.Date == selectedDate.Date;

                    <div class="@($"calendar-day {(isSelected ? "selected-day" : "")}")"
                         @onclick="@(() => ChangeDate(date))">

                        <MudText Typo="Typo.caption" Class="day-name">
                            @date.ToString("ddd").ToUpper()
                        </MudText>

                        <MudText Typo="Typo.body2" Class="day-date">
                            @date.ToString("dd MMM")
                        </MudText>

                    </div>
                }
            </div>
        </div>

        <!-- PARTIDOS -->
        <div class="matches-container">

            @if (allMatches.Count == 0)
            {
                <div class="empty-box">
                    <MudText Typo="Typo.body2">
                        Aún no hay partidos en la base de datos.
                    </MudText>
                </div>
            }
            else if (displayedMatches.Count == 0)
            {
                <div class="empty-box">
                    <MudText Typo="Typo.body2">
                        No hay partidos programados para este día.
                    </MudText>
                </div>
            }
            else
            {
                @foreach (var match in displayedMatches)
                {
                    <MudCard Elevation="0" Outlined="true" Class="match-card">
                        <MudCardContent>

                            <div class="text-center mb-2">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @(match.Stage == MatchStage.GROUP_STAGE
                                                            ? $"Grupo {match.GroupLetter}"
                                                            : match.Stage.ToString().Replace("_", " "))
                                </MudText>
                            </div>

                            <div class="match-row">
                                <div class="team text-end">
                                    @(match.HomeTeam?.Name ?? "Por definir")
                                </div>

                                <div class="match-center">
                                    @if (match.Status == MatchStatus.FINISHED)
                                    {
                                        <MudChip T="string" Color="Color.Success">
                                            @match.HomeGoals - @match.AwayGoals
                                        </MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Variant="Variant.Outlined">
                                            @match.MatchDate.LocalDateTime.ToString("HH:mm")
                                        </MudChip>
                                    }
                                </div>

                                <div class="team text-start">
                                    @(match.AwayTeam?.Name ?? "Por definir")
                                </div>
                            </div>

                            <MudDivider Class="my-2" />

                            <EditForm Model="@predictions[match.Id]"
                                      OnValidSubmit="@(() => SavePrediction(match.Id))">

                                <div class="prediction-row">
                                    <MudTextField @bind-Value="@predictions[match.Id].PredHomeGoals"
                                                  Label="Local"
                                                  Variant="Variant.Outlined"
                                                  Type="number"
                                                  Margin="Margin.Dense" />

                                    <MudTextField @bind-Value="@predictions[match.Id].PredAwayGoals"
                                                  Label="Visitante"
                                                  Variant="Variant.Outlined"
                                                  Type="number"
                                                  Margin="Margin.Dense" />
                                </div>

                                <div class="text-center mt-2">
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               ButtonType="ButtonType.Submit"
                                               Size="Size.Small">
                                        Guardar
                                    </MudButton>
                                </div>

                            </EditForm>

                        </MudCardContent>
                    </MudCard>
                }
            }
        </div>
    }

</MudContainer>