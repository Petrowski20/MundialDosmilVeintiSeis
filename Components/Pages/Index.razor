@page "/"
@using MundialDosmilVeintiSeis.Models
@using static MundialDosmilVeintiSeis.Models.Enums

<MudContainer MaxWidth="MaxWidth.Medium" Class="my-6">

    <MudText Typo="Typo.h4"
             Align="Align.Center"
             GutterBottom="true"
             Style="font-weight:600;">
        Mundial 2026 ⚽
    </MudText>

    @if (_isLoading)
    {
        <div class="d-flex justify-center my-10">
            <MudProgressCircular Indeterminate="true" />
        </div>
    }
    else
    {
        <div class="calendar-wrapper">
            <div class="calendar-strip">
                @foreach (var date in visibleDates)
                {
                    var isSelected = date.Date == selectedDate.Date;

                    <div class="@($"calendar-day {(isSelected ? "selected-day" : "")}")"
                         @onclick="@(() => ChangeDate(date))">

                        <MudText Typo="Typo.caption" Class="day-name">
                            @date.ToString("ddd").ToUpper()
                        </MudText>

                        <MudText Typo="Typo.body2" Class="day-date">
                            @date.ToString("dd MMM")
                        </MudText>

                    </div>
                }
            </div>
        </div>

        <MudSelect T="int"
                   Label="Filtrar por equipo"
                   @bind-Value="selectedTeamId"
                   Variant="Variant.Outlined"
                   Class="mb-6">
            <MudSelectItem T="int" Value="0">Todos los equipos</MudSelectItem>
            @foreach (var team in allTeams)
            {
                <MudSelectItem T="int" Value="@team.Id">@team.Name (@team.IsoCode)</MudSelectItem>
            }
        </MudSelect>

        <div class="matches-container">

            @if (allMatches.Count == 0)
            {
                <div class="empty-box">
                    <MudIcon Icon="@Icons.Material.Filled.EventBusy" Size="Size.Large" Class="mb-2" />
                    <MudText Typo="Typo.subtitle1">
                        Todavía no hay partidos cargados.
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Cuando se publiquen los encuentros del Mundial 2026 aparecerán aquí.
                    </MudText>
                </div>
            }
            else if (displayedMatches.Count == 0)
            {
                <div class="empty-box">
                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Class="mb-2" />
                    <MudText Typo="Typo.subtitle1">
                        No hay partidos para esta selección.
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Prueba con otro día o elimina el filtro de equipo.
                    </MudText>
                </div>
            }
            else
            {
                @foreach (var group in displayedMatches.GroupBy(m => m.Stage == MatchStage.GROUP_STAGE ? $"GRUPO {m.GroupLetter}" : m.Stage.ToString().Replace("_", " ")).OrderBy(g => g.Key))
                {
                    <MudText Typo="Typo.h6" Class="mt-8 mb-3" Style="font-weight: 600; text-align: center; color: #424242;">
                        @group.Key
                    </MudText>

                    <MudPaper Elevation="0" Outlined="true" Class="overflow-hidden mb-6">
                        @foreach (var match in group)
                        {
                            <div class="match-row d-flex align-center justify-space-between pa-4">

                                <div class="d-flex align-center justify-end" style="flex: 1;">
                                    <span class="fw-bold me-3" style="font-weight: 500;">@(match.HomeTeam?.Name ?? "Por definir")</span>
                                    <span class="fs-4">@(match.HomeTeam?.FlagEmoji ?? "🏳️")</span>
                                </div>

                                <div class="d-flex flex-column align-center justify-center px-4" style="min-width: 140px;">
                                    @if (match.Status == MatchStatus.FINISHED)
                                    {
                                        <span class="mb-1" style="font-size: 0.75rem; color: #757575;">Finalizado</span>
                                        <div class="score-box px-3 py-1 rounded fw-bold fs-5">
                                            @match.HomeGoals <span class="mx-1">-</span> @match.AwayGoals
                                        </div>
                                    }
                                    else if (match.Status == MatchStatus.IN_PLAY)
                                    {
                                        <span class="fw-bold pulse-text mb-1" style="font-size: 0.75rem; color: #d32f2f;">En juego</span>
                                        <div class="score-box px-3 py-1 rounded fw-bold fs-5" style="color: #d32f2f; border-color: #d32f2f;">
                                            @match.HomeGoals <span class="mx-1">-</span> @match.AwayGoals
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="fw-bold mb-1" style="font-weight: 600;">@match.MatchDate.LocalDateTime.ToString("HH:mm")</span>
                                        <span style="font-size: 0.85rem; color: #9e9e9e;">VS.</span>
                                    }
                                </div>

                                <div class="d-flex align-center justify-start" style="flex: 1;">
                                    <span class="fs-4 me-3">@(match.AwayTeam?.FlagEmoji ?? "🏳️")</span>
                                    <span class="fw-bold" style="font-weight: 500;">@(match.AwayTeam?.Name ?? "Por definir")</span>
                                </div>

                            </div>
                        }
                    </MudPaper>
                }
            }
        </div>
    }

</MudContainer>